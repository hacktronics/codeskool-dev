            },
            "highlightBlock": {
                "category": "control",
                "blockType": "control_if"
            },
            "validate": true,
            "narration": {
                "id": "gui.tutorials.jsComparisons.below",
                "default": "Add a third if. Condition — score less-than fifty. Body — log Fail. Click Run, type forty-five. Now Fail prints. The Operators section has every comparison you need for the rest of these tutorials."
            }
        },
        {
            "title": "Why three equals signs",
            "image": "/static/tutorials/steps/jsCompare_08_threeEquals.webp",
            "imageFocus": {
                "x": 50.0,
                "y": 50.0,
                "zoom": 1.0
            },
            "autoAdvance": true,
            "narration": {
                "id": "gui.tutorials.jsComparisons.threeEquals",
                "default": "JavaScript also has double-equals — two equal signs. Double-equals is loose; it says the text five and the number five are equal. Triple-equals is strict; it says they are different because one is text and the other is a number. Use triple-equals everywhere — it catches bugs that double-equals would hide."
            }
        },
        {
            "title": "Six tools, one truth",
            "image": "/static/tutorials/steps/jsCompare_09_oneTruth.webp",
