            "autoAdvance": true,
            "narration": {
                "id": "gui.tutorials.jsComparisons.sixTools",
                "default": "You know greater-than, less-than, and equals from Scratch. JavaScript has six comparison operators total — greater-than, less-than, greater-than-or-equal, less-than-or-equal, triple-equals for equal, and exclamation-equals for not-equal. Every comparison returns either true or false."
            }
        },
        {
