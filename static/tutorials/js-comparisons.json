            },
            "clearRuntimeBefore": true,
            "narration": {
                "id": "gui.tutorials.jsComparisons.oneTruth",
                "default": "Six comparison operators, every one returns true or false. Same shape as the boolean blocks you used inside Scratch's if blocks — just spelled with symbols. The next tutorial combines comparisons with and, or, and not so you can write conditions like age greater-than ten and hasPass."
            },
            "autoAdvance": true
