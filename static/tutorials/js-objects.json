            },
            "narration": {
                "id": "gui.tutorials.jsObjects.labelsNotPositions",
                "default": "Scratch lists are positional — item one, item two, item three. JavaScript has another shape called an OBJECT. Inside, each value has a LABEL — player dot name, player dot score, player dot level. Scratch has nothing like this."
            },
            "autoAdvance": true
        },
        {
            "title": "Make a player object",
