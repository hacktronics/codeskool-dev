            },
            "narration": {
                "id": "gui.tutorials.jsObjects.makePlayer",
                "default": "Make an object called player with three pairs — name is Riya, score is eighty-five, level is three. Each pair is a label and a value. In JS this writes as curly braces with key colon value pairs inside."
            },
            "validate": true,
            "highlightUI": "jsEditor"
        },
        {
