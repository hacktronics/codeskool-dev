                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.stateRefs",
                "default": "A let named index with value zero. A let named score with value zero. Four const blocks — qEl, aEl, nextBtn, scoreEl. Each uses find element by id with the matching id."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "Define showQuestion",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_06_defineShow.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.defineShow",
                "default": "Drag a function block. Name it showQuestion. No parameters. It draws the current question on the page."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "End-of-quiz guard",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_07_endGuard.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.endGuard",
                "default": "Inside showQuestion. An if block. Condition — index is not less-than the length of questions. Inside — set text of qEl to Quiz over. Set style display of aEl to none. Same for nextBtn. Then a return. return exits the function early."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "Draw the current question",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_08_drawCurrent.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.drawCurrent",
                "default": "After the if, still inside showQuestion. A set text of block. Element is qEl. Text is the question text at position index from the questions array. Then a set text of block. Element is aEl. Text is empty. The input clears between questions."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "Wire the Next button",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_09_wireNext.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.wireNext",
                "default": "Drag a when click on block. Element is nextBtn. Event is click. The body runs on every Next click."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "Check the answer",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_10_checkAnswer.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.checkAnswer",
                "default": "Inside the click body. An if block. Condition — the value of aEl made lowercase triple-equals the answer at position index made lowercase. If true, change score by one. Lowercase makes the check forgiving."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "Show score and advance",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_11_advance.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.advance",
                "default": "After the if, still inside the click body. Set text of scoreEl to a join of Score, a space, and score. Change index by one. Then call showQuestion. The next question appears."
            },
            "highlightUI": "jsEditor"
        },
        {
            "title": "First call to start the quiz",
            "image": "/static/tutorials/steps/jsCapstoneQuiz_12_firstCall.webp",
            "imageFocus": {
                "x": 45,
                "y": 50,
                "zoom": 1.2
            },
            "narration": {
                "id": "gui.tutorials.jsCapstoneQuiz.firstCall",
                "default": "Outside the listener, at the bottom of the script, add one call to showQuestion. That draws the first question when the page loads. Without it, the page starts blank."
            },
            "highlightUI": "jsEditor"
        },
