{
    "preseedExtensions": [
        "html5",
        "css"
    ],
    "preseedStarter": "htmlBoilerplate",
    "steps": [
        {
            "title": "Start with the Boilerplate",
            "image": "/static/tutorials/steps/htmlCssFlexBoilerplate.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.html_css_flex.boilerplate",
                "default": "Your workspace already has the html, head, and body blocks — every webpage starts that way (you built this in the Hello Web tutorial). Today we just focus on what we add INSIDE the body."
            }
        },
        {
            "title": "Stacked vs Side by Side",
            "image": "/static/tutorials/steps/htmlCssFlexDisplay.webp",
            "imageFocus": {
                "x": 50,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.stackedVsRow",
                "default": "By default, divs and other block elements STACK on top of each other — one per line, top to bottom. That is what you have seen so far. Today you will meet display: flex — a CSS power that arranges them SIDE BY SIDE in a row instead. Same boxes, different layout."
            }
        },
        {
            "title": "Add a Row Container",
            "image": "/static/tutorials/steps/htmlCssFlexRow.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.row",
                "default": "Drag a div inside the body. Set its class to row. This will hold the three cards we'll arrange."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_div"
            }
        },
        {
            "title": "Add Three Cards",
            "image": "/static/tutorials/steps/htmlCssFlexCards.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.cards",
                "default": "Drag three more divs inside the row, one below the other. Set each one's class to card."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_div"
            }
        },
        {
            "title": "Put Text Inside Each Card",
            "image": "/static/tutorials/steps/htmlCssFlexCardsText.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.cardsText",
                "default": "Inside each of the three cards, drag a paragraph and type Card 1, Card 2, and Card 3 — one in each."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_paragraph"
            }
        },
        {
            "title": "Add a Style Block",
            "image": "/static/tutorials/steps/htmlCssFlexStyle.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.style",
                "default": "Drag the style block inside the head."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_style"
            },
            "validate": true
        },
        {
            "title": "Pick the Row",
            "image": "/static/tutorials/steps/htmlCssFlexSelectorRow.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.selectorRow",
                "default": "Drag a selector inside the style. Replace the text with .row."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_selector"
            }
        },
        {
            "title": "Turn It Into a Flex Row",
            "image": "/static/tutorials/steps/htmlCssFlexStackedVsRow.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.display",
                "default": "Drag a display block inside the .row selector. Pick flex from the dropdown. Normally elements stack vertically — flex arranges them side by side in a row."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_display"
            }
        },
        {
            "title": "Stacked vs Side by Side",
            "image": "/static/tutorials/steps/htmlCssFlexStackedVsRow.webp",
            "imageFocus": {
                "x": 50,
                "y": 50,
                "zoom": 1
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.stackedVsRowVisual",
                "default": "Without display: flex, divs stack on top of each other — one per line, top to bottom. Add display: flex to the parent and they switch to side by side in a row. Same boxes, different layout."
            }
        },
        {
            "title": "Add a Gap Between Cards",
            "image": "/static/tutorials/steps/htmlCssFlexGap.webp",
            "imageFocus": {
                "x": 50,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.gap",
                "default": "Drag a gap block inside the selector. Replace 10 pixels with 20 pixels. Gap is the breathing room between flex items."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_gap"
            }
        },
        {
            "title": "Gap Visual",
            "image": "/static/tutorials/steps/htmlCssFlexGapVisual.webp",
            "imageFocus": {
                "x": 50,
                "y": 50,
                "zoom": 1
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.gapConcept",
                "default": "Gap is the breathing room BETWEEN flex children. With gap: 20 pixels, every pair of neighbours gets 20 pixels of space — no matter how many children, no extra code."
            }
        },
        {
            "title": "Style Each Card",
            "image": "/static/tutorials/steps/htmlCssFlexCardStyle.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.cardStyle",
                "default": "Drag another selector below the first. Replace its text with .card. Inside it, add a padding set to 20 pixels and a background-color set to lightblue — so the cards become visible boxes."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_selector"
            }
        },
        {
            "title": "See the Flex Row",
            "image": "/static/tutorials/steps/htmlCssFlexView.webp",
            "imageFocus": {
                "x": 75,
                "y": 50,
                "zoom": 1.3
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.viewTab",
                "default": "Click the View tab. Are your three cards arranged side by side in a row, with space between them?"
            },
            "highlightUI": "viewTab"
        },
        {
            "title": "How Flexbox Works",
            "image": "/static/tutorials/steps/htmlCssFlexStackedVsRow.webp",
            "imageFocus": {
                "x": 75,
                "y": 50,
                "zoom": 1.3
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFlex.recap",
                "default": "Display flex turns a container into a flex row. Gap adds space between items. Together they're how real websites build rows of cards."
            }
        }
    ]
}
