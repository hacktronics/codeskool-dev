{
    "steps": [
        {
            "title": "Start with the Boilerplate",
            "image": "/static/tutorials/steps/htmlCssFontsBoilerplate.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.html_css_fonts.boilerplate",
                "default": "Your workspace already has the html, head, and body blocks — every webpage starts that way (you built this in the Hello Web tutorial). Today we just focus on what we add INSIDE the body."
            }
        },
        {
            "title": "Style Flows Downward",
            "image": "/static/tutorials/steps/htmlCssFonts_inheritance.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.inheritance",
                "default": "Here's a useful CSS trick. If you set a colour or font on the body, every heading, paragraph, and word INSIDE the body inherits it automatically — you don't have to repeat it on each element. We say the property CASCADES down the page tree, parent to child to grandchild. So one rule like body { font-family: Comic Sans MS; } makes every paragraph, list item, and heading use Comic Sans — unless you override it on a specific element later. This is why CSS feels efficient once you get used to it: write the style once at the top, let it flow down to everything inside."
            }
        },
        {
            "title": "Add a Paragraph",
            "image": "/static/tutorials/steps/htmlCssFontsP.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.paragraph",
                "default": "Drag a paragraph inside the body. Type This text will look fancy. We'll style it next."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_paragraph"
            }
        },
        {
            "title": "Add a Style Block",
            "image": "/static/tutorials/steps/htmlCssFontsStyle.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.style",
                "default": "Drag the style block inside the head."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_style"
            },
            "validate": true
        },
        {
            "title": "Pick the Paragraph",
            "image": "/static/tutorials/steps/htmlCssFontsSelector.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.selector",
                "default": "Drag a selector inside the style. Replace the selector text with p — this picks every paragraph."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_selector"
            }
        },
        {
            "title": "Make the Text Bigger",
            "image": "/static/tutorials/steps/htmlCssFontsSize.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.size",
                "default": "Drag a font-size block inside the selector. Replace 16 pixels with 24 pixels. Bigger numbers mean bigger text."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_font_size"
            }
        },
        {
            "title": "Centre the Text",
            "image": "/static/tutorials/steps/htmlCssFontsAlign.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.align",
                "default": "Drag a text-align block inside the selector below font-size. Pick center from the dropdown. The text now sits in the middle of the page."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_text_align"
            }
        },
        {
            "title": "Change the Font",
            "image": "/static/tutorials/steps/htmlCssFontsFamily.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1.4},
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.family",
                "default": "Drag a font block inside the selector. Pick family from the property dropdown and type Arial in the value field."
            },
            "highlightBlock": {
                "category": "css",
                "blockType": "css_css_font"
            }
        },
        {
            "title": "Font Families Side by Side",
            "image": "/static/tutorials/steps/htmlCssFontsFamilies.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.families",
                "default": "Different font families have different personalities. Arial is clean and modern. Comic Sans MS is playful and round. Georgia is serif and bookish. Pick the family that matches the feeling of your page."
            }
        },
        {
            "title": "See Your Styled Text",
            "image": "/static/tutorials/steps/htmlCssFontsView.webp",
            "imageFocus": {
                "x": 75,
                "y": 50,
                "zoom": 1.3
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.viewTab",
                "default": "Click the View tab. Is the text bigger, centred, and in Arial font?"
            },
            "highlightUI": "viewTab"
        },
        {
            "title": "Sizes — px and Friends",
            "image": "/static/tutorials/steps/htmlCssFonts_units.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.units",
                "default": "When you read CSS online you'll meet several size units. Here's a quick guide. px (pixels) — one tiny dot on the screen, the simplest unit. em — relative to the current font size. rem — relative to the page's root font size. % (percent) — a percentage of the parent's size. vh and vw — percentage of the viewport (the visible browser window). For now, px is the easiest and works everywhere. As you build bigger sites you'll want em and rem so sizes scale together when zooming, and vh/vw for full-screen layouts. You don't need them all yet. Just recognise them when you see them."
            }
        },
        {
            "title": "Three Ways to Style Text",
            "image": "/static/tutorials/steps/htmlCssFontsRecap.webp",
            "imageFocus": {
                "x": 75,
                "y": 50,
                "zoom": 1.3
            },
            "narration": {
                "id": "gui.tutorials.htmlCssFonts.recap",
                "default": "Font-size sets how big the text looks. Text-align sets where it sits. Font family sets which letters it uses."
            }
        }
    ]
}
