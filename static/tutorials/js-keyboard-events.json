            },
            "narration": {
                "id": "gui.tutorials.jsKeyboardEvents.beyondMouse",
                "default": "Scratch has when key pressed hat blocks — one per key. JavaScript has ONE event, keydown, that fires for any key. Inside, you check WHICH key. Every browser game uses this pattern. Today you move a sprite with arrow keys."
            },
            "autoAdvance": true
        },
        {
            "title": "Page sprite is ready",
