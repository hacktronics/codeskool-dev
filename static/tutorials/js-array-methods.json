        "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Array Methods</title>\n</head>\n<body>\n  <script src=\"script.js\"></script>\n</body>\n</html>\n",
