                "zoom": 2.9
            },
            "highlightBlock": {
                "category": "arduino",
                "blockType": "arduino_setup"
            },
            "narration": {
                "id": "gui.tutorials.blinkLed.dragSetup",
                "default": "Drag the setup/loop block into the workspace. This is the main block for Arduino programs. Setup runs once when the program starts, and loop runs over and over."
            },
            "validate": true
        },
        {
            "title": "Add pinMode to Setup",
            "image": "/static/tutorials/steps/blinkPinMode.webp",
            "imageFocus": {
                "x": 37,
                "y": 54,
                "zoom": 2.8
            },
            "narration": {
                "id": "gui.tutorials.blinkLed.addPinMode",
                "default": "Drag a pinMode block into the setup section. Set pin to 13 and mode to OUTPUT. This tells the Arduino that pin 13 will be used to send signals out."
            },
            "highlightBlock": {
                "category": "arduino",
                "blockType": "arduino_pinModeFn"
            },
            "validate": true
        },
        {
            "title": "Add digitalWrite HIGH",
            "image": "/static/tutorials/steps/blinkDwHigh.webp",
            "imageFocus": {
                "x": 37,
                "y": 54,
                "zoom": 2.8
            },
            "narration": {
                "id": "gui.tutorials.blinkLed.dwHigh",
                "default": "Drag a digitalWrite block into the loop section. Set pin to 13 and value to HIGH. This turns the LED on."
            },
            "highlightBlock": {
                "category": "arduino",
                "blockType": "arduino_digitalWriteFn"
            },
            "validate": true
        },
        {
            "title": "Add a Delay",
            "image": "/static/tutorials/steps/blinkDelay1.webp",
            "imageFocus": {
                "x": 35,
                "y": 55,
                "zoom": 2.4
            },
            "narration": {
                "id": "gui.tutorials.blinkLed.delay1",
                "default": "Add a delay block after digitalWrite. Set it to 1000 milliseconds which is 1 second. The LED will stay on for this long."
            },
            "highlightBlock": {
                "category": "arduino",
                "blockType": "arduino_delayFn"
            },
            "validate": true
        },
        {
            "title": "Add digitalWrite LOW",
            "image": "/static/tutorials/steps/blinkDwLow.webp",
            "imageFocus": {
                "x": 32,
                "y": 55,
                "zoom": 2
            },
            "highlightBlock": {
                "category": "arduino",
                "blockType": "arduino_digitalWriteFn"
            },
            "narration": {
                "id": "gui.tutorials.blinkLed.dwLow",
                "default": "Add another digitalWrite block. Keep pin 13 but change the value to LOW. This turns the LED off."
            }
        },
        {
            "title": "Add Another Delay",
            "image": "/static/tutorials/steps/blinkComplete.webp",
            "imageFocus": {
                "x": 31,
                "y": 55,
                "zoom": 1.7
            },
            "highlightBlock": {
                "category": "arduino",
                "blockType": "arduino_delayFn"
            },
            "narration": {
                "id": "gui.tutorials.blinkLed.delay2",
                "default": "Add one more delay block with 1000 milliseconds. Your blink program is now complete! The loop will repeat: LED on, wait, LED off, wait."
            }
        },
