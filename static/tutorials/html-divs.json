        },
        {
            "title": "See the Page",
            "image": "/static/tutorials/steps/htmlDivsView.webp",
            "imageFocus": {
                "x": 75,
                "y": 50,
                "zoom": 1.3
            },
            "narration": {
                "id": "gui.tutorials.htmlDivs.viewTab",
                "default": "Click the View tab. The div itself is invisible — it's just a wrapper. The class name is waiting for CSS to make it stand out."
            },
            "highlightUI": "viewTab"
        },
        {
            "title": "Your Page Is a Tree",
            "image": "/static/tutorials/steps/htmlDom_pageAsTree.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlDivs.pageAsTree",
                "default": "Look at what you've built. The body holds a div. The div holds a heading and a paragraph. Picture this as a TREE — the body is the trunk, the div is a branch, the heading and paragraph are leaves on that branch. Every HTML page is a tree like this — tags hold other tags, which hold more tags. This shape has a name: the DOM (short for Document Object Model). When you read about HTML online, you'll see that word a lot. Just remember — the DOM is your page drawn as a tree, with the outer tags closer to the trunk and the inner tags out at the leaves. Selectors, CSS rules, and animations all work by walking this tree."
            }
        },
        {
            "title": "Divs Group, Classes Label",
            "image": "/static/tutorials/steps/htmlDivsLabelledBox.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlDivs.recap",
                "default": "A div groups elements together. The class is a name we attach to a div so CSS can find it later and change how it looks."
            }
        }
    ]
