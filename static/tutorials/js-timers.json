            },
            "narration": {
                "id": "gui.tutorials.jsTimers.saveAndWatch",
                "default": "Click Save. Default name is script. Click Save. Then View Files, open index.html. The clock counts up one, two, three. At ten it freezes and prints done."
            },
            "highlightUI": "saveButton"
        },
        {
            "title": "Timers everywhere",
