{
    "steps": [
        {
            "title": "Start with the Boilerplate",
            "image": "/static/tutorials/steps/htmlFormsBoilerplate.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.html_forms.boilerplate",
                "default": "Your workspace already has the html, head, and body blocks — every webpage starts that way (you built this in the Hello Web tutorial). Today we just focus on what we add INSIDE the body."
            }
        },
        {
            "title": "Drag a Form",
            "image": "/static/tutorials/steps/htmlFormsForm.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlForms.dragForm",
                "default": "Drag the form block inside the body. A form collects what someone types or chooses on your page."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_form"
            },
            "validate": true
        },
        {
            "title": "Add a Label",
            "image": "/static/tutorials/steps/htmlFormsLabel.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlForms.label",
                "default": "Drag a label block inside the form. Type Your name. The label tells the reader what to type."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_label"
            }
        },
        {
            "title": "Add an Input Box",
            "image": "/static/tutorials/steps/htmlFormsInput.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlForms.input",
                "default": "Drag an input block below the label, still inside the form. Click the placeholder field and type Enter your name. The placeholder shows a hint inside the empty box."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_input"
            }
        },
        {
            "title": "Add a Button",
            "image": "/static/tutorials/steps/htmlFormsButton.webp",
            "imageFocus": {
                "x": 55,
                "y": 50,
                "zoom": 1.4
            },
            "narration": {
                "id": "gui.tutorials.htmlForms.button",
                "default": "Drag a button block below the input, still inside the form. Type Send. The button is what the reader clicks when they're done."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_button"
            }
        },
        {
            "title": "Try Your Form",
            "image": "/static/tutorials/steps/htmlFormsView.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1.4},
            "narration": {
                "id": "gui.tutorials.htmlForms.viewTab",
                "default": "Click the View tab. Try typing your name in the box. Do you see the placeholder hint disappear when you start typing?"
            },
            "highlightUI": "viewTab"
        },
        {
            "title": "Why the Page Reloads When You Click Send",
            "image": "/static/tutorials/steps/htmlFormsButtonReloadWarning.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlForms.buttonReload",
                "default": "Heads up — clicking Send right now reloads the page. That's because the form has no action address yet. Without action, the form doesn't know where to send the data, so the browser just refreshes the page."
            }
        },
        {
            "title": "Where Does the Data Go?",
            "image": "/static/tutorials/steps/htmlFormsWhereDataGoes.webp",
            "imageFocus": {"x": 50, "y": 50, "zoom": 1},
            "narration": {
                "id": "gui.tutorials.htmlForms.whereDataGoes",
                "default": "When the reader fills in your form and clicks Send, the browser tries to send the data somewhere. WHERE? That depends on the form's action — the address you give it. We have not given this form an action yet, so clicking Send will not go anywhere — it just reloads. For now, you have built the LOOK of a form. Sending it for real is a bigger topic for another tutorial."
            }
        },
        {
            "title": "Forms Collect Input",
            "image": "/static/tutorials/steps/htmlFormsRecap.webp",
            "imageFocus": {
                "x": 75,
                "y": 50,
                "zoom": 1.3
            },
            "narration": {
                "id": "gui.tutorials.htmlForms.recap",
                "default": "A form has three parts: a label that tells the reader what to type, an input box where they type, and a button to submit. Together they collect information from the reader."
            }
        }
    ]
}
