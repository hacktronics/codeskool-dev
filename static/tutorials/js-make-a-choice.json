            "highlightBlock": {
                "category": "control",
                "blockType": "control_if"
            },
            "validate": true,
            "narration": {
                "id": "gui.tutorials.jsMakeAChoice.ifShape",
                "default": "Drag an if block from Control. The slot is the condition — age greater-than-or-equal ten. The body is what runs if the condition is true — a log to console block saying You can join. Same C-shape you used in Scratch."
            }
        },
        {
            "title": "Indentation makes it readable",
            "image": "/static/tutorials/steps/jsChoice_05_indented.webp",
