                "x": 50,
                "y": 50,
                "zoom": 1.0
            },
            "autoAdvance": true,
            "narration": {
                "id": "gui.tutorials.jsMakeAChoice.indented",
                "default": "Look at the Code panel on the right. Lines inside the if body are indented by four spaces. Curly braces — open brace, close brace — mark where the if body starts and ends. Indentation does not change what runs; it just makes the code easier for humans to read."
            }
        },
        {
            "title": "Add the else half",
            "image": "/static/tutorials/steps/jsChoice_06_elseHalf.webp",
            "imageFocus": {
                "x": 27.3,
