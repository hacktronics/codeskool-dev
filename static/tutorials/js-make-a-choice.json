            "highlightBlock": {
                "category": "control",
                "blockType": "control_if_else"
            },
            "validate": true,
            "narration": {
                "id": "gui.tutorials.jsMakeAChoice.elseHalf",
                "default": "Replace the if block with an if-else block. In the else body, log You are too young. Same as Scratch's if-else — two branches, exactly one runs depending on the condition."
            }
        },
        {
