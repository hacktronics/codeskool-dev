        {
            "title": "Parts of a Web Address",
            "image": "/static/tutorials/steps/htmlLinks_urlAnatomy.webp",
            "imageFocus": {
                "x": 50,
                "y": 50,
                "zoom": 1
            },
            "narration": {
                "id": "gui.tutorials.htmlLinks.urlAnatomy",
                "default": "Look at the URL you typed. A web address has parts — and once you know them, web addresses stop feeling random. https:// is the PROTOCOL — the language the browser uses to talk to the server. The next part is the DOMAIN — the name of the site (like google.com or youtube.com). After the slash comes the PATH — which page on that site you want. Sometimes there's a question mark and extra info called QUERY parameters. Every link you'll write breaks down this way. Knowing the parts helps you spot bad links — wrong protocol, wrong domain, missing path — and write working ones."
            },
            "_sourceCrop": {
                "x": 50,
                "y": 50,
                "zoom": 1
            },
            "autoAdvance": true
        },
        {
            "title": "Put Text Inside the Link",
            "image": "/static/tutorials/steps/htmlLinksText.webp",
            "imageFocus": {
                "x": 38,
                "y": 56,
                "zoom": 1.8
            },
            "narration": {
                "id": "gui.tutorials.htmlLinks.addText",
                "default": "Drag a text block inside the link — between the link's open and close. Type Wikipedia Adventure. This is the words your reader clicks."
            },
            "highlightBlock": {
                "category": "html5",
                "blockType": "html5_html5_text"
            },
            "_sourceCrop": {
                "x": 38,
                "y": 56,
                "zoom": 1.8
            }
        },
